<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" /> <!-- если у вас есть свои стили -->
    <style>
        .navbar-brand { font-weight: bold; }
        .nav-link.active { font-weight: bold; color: #0d6efd !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">🚔 WebApplication1</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">Вход</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Main">Главная</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Incidents">Инциденты</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Police">Полиция</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Prava">Права</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Stat">Статистика</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/VehicleAndOwners">ТС и владельцы</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/AddIncident">+ Инцидент</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/AddUser">+ Пользователь</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            © 2026 WebApplication1 — Система учёта инцидентов
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>